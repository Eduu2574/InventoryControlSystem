<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <title>REPORTE SATURACIÓN</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="/script/reporteSaturacion.js" defer></script>
</head>

<body class="bg-gray-900 text-gray-200 min-h-screen p-6">

  <div class="max-w-7xl mx-auto">

    <div class="flex justify-between items-center mb-6">
      <h1 class="text-2xl font-bold uppercase tracking-widest">
        REPORTE SATURACIÓN DE PRODUCTOS
      </h1>

      <a href="/mainPage" class="px-4 py-2 bg-indigo-600 rounded hover:bg-indigo-700">
        ← Volver
      </a>
    </div>

    <!-- AÑADO FILTROS POR ESTADO -->
    <!-- ✅ FILTRO POR ESTADO -->
    <div class="flex items-center gap-4 mb-4">

      <div>
        <label class="text-xs text-gray-400 block mb-1">Estado</label>
        <select id="filtroEstado" class="bg-gray-800 border border-gray-600 rounded px-2 py-1 text-sm">

          <option value="">Todos</option>
          <option value="OPTIMO">Óptimos</option>
          <option value="RIESGO">Riesgo</option>
          <option value="CRITICO">Críticos</option>

        </select>
      </div>

      <button onclick="aplicarFiltroEstado()"
        class="mt-5 px-4 py-2 bg-indigo-600 hover:bg-indigo-500 rounded text-sm font-bold">
        Filtrar
      </button>

      <button onclick="limpiarFiltroEstado()" class="mt-5 px-3 py-2 bg-gray-700 hover:bg-gray-600 rounded text-sm">
        Limpiar
      </button>

    </div>
    <!-- MOSTRAR FÁBRICA ACTIVA -->
    <p class="text-sm text-gray-400 mb-2">
      Fábrica activa:
      <span id="nombreFabrica" class="text-blue-400 font-bold"></span>
    </p>

    <!-- RESUMEN -->
    <div id="resumenSaturacion" class="grid grid-cols-3 gap-4 mb-6 text-center">
    </div>

    <!-- LISTA DE PRODUCTOS -->
    <div class="overflow-x-auto border border-gray-700 rounded-xl">
      <table class="w-full text-sm">
        <thead class="bg-gray-800 text-gray-300">
          <tr>
            <th class="p-4 text-left text-lg font-bold">PRODUCTO</th>
            <th class="p-4 text-left text-lg font-bold">STOCK ACTUAL</th>
            <th class="p-4 text-left text-lg font-bold">STOCK MÍNIMO</th>
            <th class="p-4 text-left text-lg font-bold">ESTADO</th>
          </tr>
        </thead>

        <tbody id="tablaSaturacion" class="divide-y divide-gray-700">
          <tr>
            <td colspan="4" class="p-4 text-center text-gray-400">
              Cargando datos...
            </td>
          </tr>
        </tbody>
      </table>
    </div>



</body>

</html>