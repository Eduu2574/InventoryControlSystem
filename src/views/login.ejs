<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - ICS </title>
    <!--INCLUIMOS LA CABECERA-->
    <%- include('partials/head.ejs') %>

        <style>
            /* Edición */
            .intro-text {
                animation:
                    fadeIn 2s ease-in-out,
                    slideInUp 1s ease-out 1s;
                animation-fill-mode:
                    forwards;
                opacity:
                    0;
            }

            @keyframes fadeOutAndHide {
                0% {
                    opacity:
                        1;
                    transform:
                        scale(1);
                }

                100% {
                    opacity:
                        0;
                    transform:
                        scale(0.95);
                    display:
                        none;
                }
            }

            .hide-intro {
                animation:
                    fadeOutAndHide 0.6s ease-in-out forwards;
            }

            .log-text {
                color:
                    black;
            }
        </style>
</head>

<body class="flex flex-col min-h-screen bg-gray-900 text-white">    <!--INCLUIMOS EL MODAL-->
<div class="flex-1 flex items-center justify-center">

    <!-- Animación PARA PARECER QUE ESTÁ CARGANDO-->
    <div id="intro" class="text-center intro-text">
        <!-- Imagen -->
        <img src="/assets/icono.png" alt="Logo Horse Logistics" class="mx-auto mb-4 w-24 h-24 object-contain">

        <!-- Título PRINCIPAL DE LA PÁGINA -->
         
        <h1 class="text-4xl font-bold mb-4">Inventory Control System (ICS)</h1>

        <!-- Loading + Spinner -->
        <div class="inline-flex items-center space-x-2">
            <p class="text-lg mb-0">Cargando...</p>
            <div class="spinner-border spinner-border-sm text-light" role="status" style="width: 1rem; height: 1rem;">
            </div>
        </div>
    </div>
    <div id="loginForm"
        class="hidden w-full max-w-md p-8 bg-gray-800 rounded-lg shadow-md animate-slideInUp">

        <h2 class="text-2xl font-bold mb-6 text-center">Inicio de sesión</h2>

        <img src="/assets/icono.png"
             alt="Logo Horse Logistics"
             class="mx-auto mb-4 w-48 object-contain">

        <form>
            <div class="mb-4">
                <label for="email" class="form-label">Email</label>
                <input type="email" id="email"
                    class="form-control"
                    placeholder="ejemplo@gmail.com"
                    required />
            </div>

            <div class="mb-4">
                <label for="password" class="form-label">Password</label>
                <input type="password" id="password"
                    class="form-control"
                    required />
            </div>

            <div class="d-grid gap-2">
                <button type="submit"
                    class="btn btn-primary w-full mb-2">
                    Iniciar sesión
                </button>
                <a href="/register"
                   class="btn btn-success w-full mt-2 text-center flex items-center justify-center">
                    Registrar usuario
                </a>
            </div>
        </form>
    </div>
</div>


    <script>

        //Creamos una instancia del formulario
        const formulario_inicio_sesion = document.querySelector('#loginForm form');



        //Añadimos el escuchador para cuando se complete el formularioo

        formulario_inicio_sesion.addEventListener('submit', async (e) => {
            e.preventDefault();

            const email = document.querySelector('#email').value;
            const password = document.querySelector('#password').value;


            const response = await fetch('/login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email, password }),
                credentials: 'include'
            });

            if (response.ok) {
                window.location.href = '/mainPage';
            } else {
                alert('Credenciales incorrectas');
            }
        });


        /**
        Evento para cuando finalice la carga
         */

        window.addEventListener("load", () => {
            setTimeout(() => {
                //Creamos una instancia de los elementos necesarios
                const intro = document.getElementById("intro"), formulario_inicio_sesion = document.getElementById("loginForm");

                //Añadimos el estilo para el contenedor de la animación
                intro.classList.add("hide-intro");

                //Añadimos un timeOut
                setTimeout(() => {
                    intro.classList.add("hidden");
                    formulario_inicio_sesion.classList.remove("hidden");
                }, 600);
            }, 2000);
        });
    </script>
    <footer class="mt-auto bg-gray-900 text-gray-400 text-xs py-4 text-center border-t border-gray-800">
        <span class="font-semibold text-gray-300">Inventory Control System (ICS)</span> ·
        Developed by <span class="text-blue-400">Eduardo Domínguez‑Toribio</span> © 2026
        <br>
        <a href="https://github.com/eduu2574" target="_blank" class="text-blue-400 hover:underline">
            Vísita mi página de Github
        </a>
    </footer>
</body>

</html>